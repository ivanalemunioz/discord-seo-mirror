---
import { marked } from 'marked';

const { message } = Astro.props;
const html = message.content ? marked.parse(message.content, { breaks: true }) : '';

const isImage = (name: string) => /\.(png|jpe?g|gif|webp|svg)$/i.test(name);
const isVideo = (name: string) => /\.(mp4|webm|mov|m4v)$/i.test(name);
const isAudio = (name: string) => /\.(mp3|wav|ogg|m4a)$/i.test(name);
const isPdf = (name: string) => /\.pdf$/i.test(name);
---

<div class="py-3 border-b border-line/40 last:border-b-0">
  <div class="text-sm font-semibold text-slate-200">{message.author} <span class="text-xs text-muted font-normal">{new Date(message.timestamp).toISOString()}</span></div>
  {message.content ? (
    <div class="mt-1 prose prose-invert max-w-none discord-message-stream" set:html={html} />
  ) : null}

  {message.attachments?.length ? (
    <div class="mt-2 space-y-3">
      {message.attachments.map((a: { url: string; filename: string }) => {
        const renderable = isImage(a.filename) || isVideo(a.filename) || isAudio(a.filename) || isPdf(a.filename);
        return (
          <div>
            {isImage(a.filename) ? (
              <a href={a.url} target="_blank" rel="noreferrer">
                <img src={a.url} alt={a.filename} loading="lazy" class="max-h-96 rounded-lg border border-line" />
              </a>
            ) : isVideo(a.filename) ? (
              <video controls preload="metadata" class="w-full max-h-96 rounded-lg border border-line">
                <source src={a.url} />
              </video>
            ) : isAudio(a.filename) ? (
              <audio controls preload="none" class="w-full">
                <source src={a.url} />
              </audio>
            ) : isPdf(a.filename) ? (
              <iframe src={a.url} title={a.filename} class="w-full h-96 rounded-lg border border-line" loading="lazy"></iframe>
            ) : null}
            {!renderable ? (
              <div class="mt-1 text-sm">
                <a href={a.url} target="_blank" rel="noreferrer">{a.filename}</a>
              </div>
            ) : null}
          </div>
        );
      })}
    </div>
  ) : null}
</div>
