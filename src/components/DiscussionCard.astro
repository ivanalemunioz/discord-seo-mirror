---
const { item } = Astro.props;
---

<article class="card p-4 hover:border-blurple transition-colors">
  <a href={`/community/${item.slug}`} class="block">
    <h3 class="text-lg font-semibold">{item.data.title}</h3>
    <p class="text-sm text-muted mt-1">#{item.data.channelName} · {item.data.messageCount} messages</p>
    <p class="text-sm mt-3 line-clamp-3 text-slate-300">{item.data.excerpt}</p>
  </a>
  <div class="mt-4 flex flex-wrap gap-2">
    {item.data.tags?.slice(0, 4).map((tag: string) => <span class="px-2 py-1 rounded-md bg-panel text-xs">{tag}</span>)}
  </div>
</article>
