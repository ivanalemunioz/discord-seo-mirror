---
import MainLayout from '@/layouts/MainLayout.astro';
import { getChannelNav } from '@/lib/content';
import { t } from '@/lib/i18n';
const channels = await getChannelNav();
const grouped = new Map<string, typeof channels>();
for (const c of channels) {
  const key = c.category || 'Ungrouped';
  if (!grouped.has(key)) grouped.set(key, [] as any);
  grouped.get(key)!.push(c);
}
---
<MainLayout title={t('channels')} channels={channels}>
  <h1 class="text-2xl font-semibold">{t('channels')}</h1>

  {[...grouped.entries()].map(([cat, list]) => (
    <section class="mt-6">
      {cat !== 'Ungrouped' ? <h2 class="text-sm uppercase tracking-wide text-muted mb-2">{cat}</h2> : null}
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-3">
        {list.map((c) => (
          <a href={`/channels/${c.slug}`} class="card p-4 hover:border-blurple transition-colors">
            <div class="text-base font-medium flex items-center gap-2">
              {c.iconKind === 'forum' ? (
                <svg viewBox="0 0 24 24" aria-hidden="true" class="h-4 w-4 text-muted"><path fill="currentColor" d="M4 4h16a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2H9l-5 4v-4H4a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2Zm2 5h12v2H6V9Zm0-3h12v2H6V6Z"/></svg>
              ) : c.iconKind === 'rules' ? (
                <svg viewBox="0 0 24 24" aria-hidden="true" class="h-4 w-4 text-muted"><path fill="currentColor" d="M5 3h14a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2Zm3 5h8v2H8V8Zm0 4h8v2H8v-2Zm0 4h5v2H8v-2Z"/></svg>
              ) : c.iconKind === 'updates' ? (
                <svg viewBox="0 0 24 24" aria-hidden="true" class="h-4 w-4 text-muted"><path fill="currentColor" d="M3 10v4h3l4 3V7L6 10H3Zm12.5 2a4.5 4.5 0 0 0-2.5-4.03v8.06A4.5 4.5 0 0 0 15.5 12Zm0-9v2a9 9 0 0 1 0 18v2a11 11 0 0 0 0-22Z"/></svg>
              ) : (
                <span class="text-muted">#</span>
              )}
              <span>{c.name}</span>
            </div>
            <div class="text-sm text-muted mt-1">{c.count} messages</div>
          </a>
        ))}
      </div>
    </section>
  ))}
</MainLayout>
