---
import MainLayout from '@/layouts/MainLayout.astro';
import { getChannelNav } from '@/lib/content';
const channels = await getChannelNav();
---
<MainLayout title="Channels" channels={channels}>
  <h1 class="text-2xl font-semibold">Channels</h1>
  <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 mt-6">
    {channels.map((c) => (
      <a href={`/channels/${c.slug}`} class="card p-4 hover:border-blurple transition-colors">
        <div class="text-lg font-medium"># {c.name}</div>
        <div class="text-sm text-muted mt-1">{c.count} discussions</div>
      </a>
    ))}
  </div>
</MainLayout>
