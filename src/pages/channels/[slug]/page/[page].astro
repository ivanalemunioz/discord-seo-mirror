---
import MainLayout from '@/layouts/MainLayout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import MessageItem from '@/components/MessageItem.astro';
import { getChannelNav, getChannelPage, getMessagePageMap } from '@/lib/content';
import { t } from '@/lib/i18n';

export async function getStaticPaths() {
  const channels = await getChannelNav();
  const paths: { params: { slug: string; page: string } }[] = [];

  for (const c of channels) {
    for (let p = 1; p <= (c.totalPages || 1); p++) {
      paths.push({ params: { slug: c.slug, page: String(p) } });
    }
  }

  return paths;
}

const { slug, page } = Astro.params;
const currentPage = Number(page || '1');
const channels = await getChannelNav();
const channel = channels.find((c) => c.slug === slug);
const pageData = channel ? await getChannelPage(channel.id, currentPage) : null;
const messagePageMap = channel ? await getMessagePageMap(channel.id) : new Map<string, number>();
const inviteUrl = import.meta.env.PUBLIC_DISCORD_INVITE_URL || '';
const hasInvite = Boolean(inviteUrl);

const olderHref = currentPage > 1 ? `/channels/${slug}/page/${currentPage - 1}` : null;
const newerHref = channel && currentPage < channel.totalPages ? `/channels/${slug}/page/${currentPage + 1}` : null;
const isForum = channel?.channelType === 15;

function shouldShowAuthor(messages: Array<{ author: string; timestamp: string }>, i: number) {
  const prev = messages[i - 1];
  if (!prev) return true;
  const withinHour = (new Date(messages[i].timestamp).getTime() - new Date(prev.timestamp).getTime()) <= 3600000;
  const sameAuthor = prev.author === messages[i].author;
  return !(sameAuthor && withinHour);
}
---
<MainLayout title={`#${channel?.name ?? slug}`} channels={channels}>
  <section>
    <header class="fixed top-0 left-0 right-0 lg:left-[280px] z-20 bg-background/95 backdrop-blur border-b border-line pb-3 px-4 lg:px-8 pt-4">
      <Breadcrumbs items={[{ label: 'Channels', href: '/channels' }, { label: `#${channel?.name ?? slug}`, href: `/channels/${slug}` }]} />
      <h1 class="text-xl md:text-2xl font-semibold"># {channel?.name}</h1>
    </header>

    <article id="message-root" class={`mt-24 ${hasInvite ? 'pb-16' : 'pb-4'}`}>
      {!pageData || !pageData.messages?.length ? (
        <p class="text-muted">{t('thisPageMissing')}</p>
      ) : (
        <div class="mb-4 flex items-center justify-center">
          {olderHref ? <a class="text-sm text-blue-300 hover:text-blue-200" href={olderHref}>↑ {t('oldMessages')}</a> : <span class="text-muted text-sm">{t('oldestPage')}</span>}
        </div>
      )}

      {!pageData || !pageData.messages?.length ? null : isForum ? (
        <div class="space-y-3">
          {pageData.messages.map((m) => (
            <a href={`/threads/${m.thread?.id}`} class="block rounded-lg border border-line bg-surface p-4 hover:border-blurple transition-colors">
              <div class="text-sm font-semibold text-slate-200 flex items-center gap-2"><span aria-hidden="true">💬</span>{m.thread?.name || m.content || 'Thread'}</div>
              <div class="mt-1 text-sm text-slate-300 line-clamp-2">{m.thread?.preview || m.content || ''}</div>
              <div class="mt-2 text-xs text-muted"><time data-local-time datetime={m.timestamp}>{new Date(m.timestamp).toISOString()}</time> · {m.author} · {m.thread?.messageCount || 0} {t('messagesWord')}</div>
            </a>
          ))}
        </div>
      ) : (
        <>
          {pageData.messages.map((m, i) => {
            const targetPage = m.replyTo?.id ? messagePageMap.get(m.replyTo.id) : undefined;
            const msg = targetPage
              ? { ...m, replyTo: { ...m.replyTo, href: targetPage === currentPage ? `#m-${m.replyTo?.id}` : `/channels/${slug}/page/${targetPage}#m-${m.replyTo?.id}` } }
              : m;
            return <MessageItem message={msg} showAuthor={shouldShowAuthor(pageData.messages, i)} />;
          })}
        </>
      )}

      {pageData && pageData.messages?.length ? (
        <div class="mt-6 flex items-center justify-center">
          {newerHref ? <a class="text-sm text-blue-300 hover:text-blue-200" href={`${newerHref}?top=1`}>{t('newestMessages')} ↓</a> : <span class="text-muted text-sm">{t('alreadyNewest')}</span>}
        </div>
      ) : null}
    </article>

    <script>
      // @ts-nocheck
      const focusMessage = (id) => {
        if (!id) return;
        const el = document.getElementById(id);
        if (!el) return;
        el.scrollIntoView({ behavior: 'smooth', block: 'center' });
        el.classList.add('message-focus-highlight');
        setTimeout(() => el.classList.remove('message-focus-highlight'), 3000);
      };

      requestAnimationFrame(() => {
        if (location.hash) {
          focusMessage(location.hash.slice(1));
        } else if (new URLSearchParams(location.search).get('top') === '1') {
          window.scrollTo({ top: 0, behavior: 'auto' });
        } else {
          window.scrollTo({ top: document.documentElement.scrollHeight, behavior: 'auto' });
        }
      });

      document.addEventListener('click', (ev) => {
        const a = ev.target instanceof Element ? ev.target.closest('a[href^="#m-"]') : null;
        if (!a) return;
        ev.preventDefault();
        const id = a.getAttribute('href')?.slice(1);
        if (!id) return;
        history.replaceState(null, '', `#${id}`);
        focusMessage(id);
      });

      window.addEventListener('hashchange', () => {
        focusMessage(location.hash.slice(1));
      });
    </script>

    {hasInvite ? (
      <div class="fixed bottom-0 left-0 right-0 lg:left-[280px] z-30 group bg-background/95 border-t border-line">
        <div class="p-3 lg:px-6">
          <div class="flex items-center gap-2 bg-surface border border-line rounded-lg px-3 py-2 text-sm text-muted pointer-events-none">
            <span class="flex-1">Write a message...</span>
            <button class="h-8 px-3 rounded-md bg-panel border border-line text-slate-300 pointer-events-none">Send</button>
          </div>
          <a href={inviteUrl} target="_blank" rel="noreferrer" class="absolute -top-10 left-1/2 -translate-x-1/2 whitespace-nowrap bg-panel border border-line rounded-md px-3 py-1 text-xs text-slate-200 opacity-0 pointer-events-none group-hover:opacity-100 transition-opacity">
            Join to the community
          </a>
        </div>
      </div>
    ) : null}
  </section>
</MainLayout>
