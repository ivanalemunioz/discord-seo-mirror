---
import { render } from 'astro:content';
import MainLayout from '@/layouts/MainLayout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import { getDiscussions, getChannelNav } from '@/lib/content';

export async function getStaticPaths() {
  const channels = await getChannelNav();
  const discussions = await getDiscussions();

  const paths: { params: { slug: string; page: string } }[] = [];
  for (const channel of channels) {
    const pages = discussions
      .filter((d) => d.data.channelId === channel.id)
      .map((d) => d.data.pageNumber);
    const maxPage = pages.length ? Math.max(...pages) : 1;

    for (let p = 1; p <= maxPage; p++) {
      paths.push({ params: { slug: channel.slug, page: String(p) } });
    }
  }

  return paths;
}

const { slug, page } = Astro.params;
const currentPage = Number(page || '1');
const channels = await getChannelNav();
const channel = channels.find((c) => c.slug === slug);

const entry = (await getDiscussions()).find(
  (d) => d.data.channelId === channel?.id && d.data.pageNumber === currentPage
);

const { Content } = entry ? await render(entry) : { Content: null };
const totalPages = entry?.data.totalPages ?? 1;

const olderHref = currentPage > 1 ? `/channels/${slug}/page/${currentPage - 1}` : null;
const newerHref = currentPage < totalPages ? `/channels/${slug}/page/${currentPage + 1}` : null;
---
<MainLayout title={`#${channel?.name ?? slug} · Page ${currentPage}`} channels={channels}>
  <section>
    <header class="sticky top-0 z-10 bg-background/95 backdrop-blur border-b border-line pb-3">
      <Breadcrumbs items={[{ label: 'Channels', href: '/channels' }, { label: `#${channel?.name ?? slug}`, href: `/channels/${slug}` }, { label: `Page ${currentPage}` }]} />
      <h1 class="text-xl md:text-2xl font-semibold"># {channel?.name}</h1>
    </header>

    <article id="message-root" class="card p-4 md:p-6 mt-4">
      <div class="mb-4 flex items-center justify-between">
        {olderHref ? <a class="channel-row" href={olderHref}>← Older messages</a> : <span class="text-muted text-sm">Oldest page</span>}
        <span class="text-xs text-muted">Page {currentPage} / {totalPages}</span>
      </div>

      {entry && Content ? (
        <div class="prose prose-invert max-w-none discord-message-stream">
          <Content />
        </div>
      ) : (
        <p class="text-muted mt-6">This page does not exist yet.</p>
      )}

      <div class="mt-6 flex items-center justify-between">
        {newerHref ? <a class="channel-row" href={newerHref}>Newest messages →</a> : <span class="text-muted text-sm">Already newest page</span>}
        {entry ? <a class="channel-row" href={`/community/${entry.slug}`}>Permalink page ↗</a> : <span />}
      </div>
    </article>

    <script>
      requestAnimationFrame(() => {
        window.scrollTo({ top: document.documentElement.scrollHeight, behavior: 'auto' });
      });
    </script>
  </section>
</MainLayout>
