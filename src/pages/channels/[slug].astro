---
import { render } from 'astro:content';
import MainLayout from '@/layouts/MainLayout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import { getDiscussions, getChannelNav } from '@/lib/content';

export async function getStaticPaths() {
  const channels = await getChannelNav();
  return channels.map((c) => ({ params: { slug: c.slug } }));
}

const { slug } = Astro.params;
const channels = await getChannelNav();
const channel = channels.find((c) => c.slug === slug);

const channelPages = (await getDiscussions())
  .filter((d) => d.data.channelId === channel?.id)
  .sort((a, b) => a.data.pageNumber - b.data.pageNumber);

const latest = channelPages.at(-1);
const { Content } = latest ? await render(latest) : { Content: null };
---
<MainLayout title={`#${channel?.name ?? slug}`} channels={channels}>
  <Breadcrumbs items={[{ label: 'Channels', href: '/channels' }, { label: `#${channel?.name ?? slug}` }]} />
  <h1 class="text-2xl font-semibold"># {channel?.name}</h1>

  {latest && Content ? (
    <>
      <p class="text-sm text-muted mt-2">Latest messages. Page {latest.data.pageNumber} of {latest.data.totalPages}.</p>
      <article class="card p-6 mt-6">
        <div class="prose prose-invert max-w-none">
          <Content />
        </div>
      </article>

      <nav class="mt-8 flex items-center justify-between">
        {latest.data.pageNumber > 1
          ? <a class="channel-row" href={`/channels/${slug}/page/${latest.data.pageNumber - 1}`}>← Older messages</a>
          : <span class="text-muted text-sm">Start of channel history</span>}
        <a class="channel-row" href={`/community/${latest.slug}`}>Permalink page ↗</a>
      </nav>
    </>
  ) : (
    <p class="text-muted mt-4">No messages synced yet for this channel.</p>
  )}
</MainLayout>
