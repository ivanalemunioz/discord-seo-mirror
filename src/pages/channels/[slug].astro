---
import MainLayout from '@/layouts/MainLayout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import MessageItem from '@/components/MessageItem.astro';
import { getChannelNav, getChannelPage } from '@/lib/content';

export async function getStaticPaths() {
  const channels = await getChannelNav();
  return channels.map((c) => ({ params: { slug: c.slug } }));
}

const { slug } = Astro.params;
const channels = await getChannelNav();
const channel = channels.find((c) => c.slug === slug);
const latestPageNumber = channel?.totalPages || 1;
const page = channel ? await getChannelPage(channel.id, latestPageNumber) : null;
---
<MainLayout title={`#${channel?.name ?? slug}`} channels={channels}>
  {channel && page ? (
    <section>
      <header class="fixed top-0 left-0 right-0 lg:left-[280px] z-20 bg-background/95 backdrop-blur border-b border-line pb-3 px-4 lg:px-8 pt-4">
        <Breadcrumbs items={[{ label: 'Channels', href: '/channels' }, { label: `#${channel.name}` }]} />
        <h1 class="text-xl md:text-2xl font-semibold"># {channel.name}</h1>
      </header>

      <article id="message-root" class="mt-24">
        <div class="mb-4 flex items-center justify-between">
          {page.pageNumber > 1
            ? <a class="text-sm text-blue-300 hover:text-blue-200" href={`/channels/${slug}/page/${page.pageNumber - 1}`}>← Older messages</a>
            : <span class="text-muted text-sm">Start of channel history</span>}
          <span />
        </div>

        {page.messages.map((m) => <MessageItem message={m} />)}
      </article>

      <script>
        // @ts-nocheck
        const focusMessage = (id) => {
          if (!id) return;
          const el = document.getElementById(id);
          if (!el) return;
          el.scrollIntoView({ behavior: 'smooth', block: 'center' });
          el.classList.add('message-focus-highlight');
          setTimeout(() => el.classList.remove('message-focus-highlight'), 3000);
        };

        requestAnimationFrame(() => {
          if (location.hash) {
            focusMessage(location.hash.slice(1));
          } else {
            window.scrollTo({ top: document.documentElement.scrollHeight, behavior: 'auto' });
          }
        });

        document.addEventListener('click', (ev) => {
          const a = ev.target instanceof Element ? ev.target.closest('a[href^="#m-"]') : null;
          if (!a) return;
          ev.preventDefault();
          const id = a.getAttribute('href')?.slice(1);
          if (!id) return;
          history.replaceState(null, '', `#${id}`);
          focusMessage(id);
        });

        window.addEventListener('hashchange', () => {
          focusMessage(location.hash.slice(1));
        });
      </script>
    </section>
  ) : (
    <p class="text-muted mt-4">No messages synced yet for this channel.</p>
  )}
</MainLayout>
