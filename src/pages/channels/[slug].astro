---
import MainLayout from '@/layouts/MainLayout.astro';
import DiscussionCard from '@/components/DiscussionCard.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import { getDiscussions, getChannelNav } from '@/lib/content';

export async function getStaticPaths() {
  const channels = await getChannelNav();
  return channels.map((c) => ({ params: { slug: c.slug } }));
}

const { slug } = Astro.params;
const channels = await getChannelNav();
const channel = channels.find((c) => c.slug === slug);
const discussions = (await getDiscussions()).filter((d) => d.data.channelId === channel?.id);
const PAGE_SIZE = 10;
const totalPages = Math.max(1, Math.ceil(discussions.length / PAGE_SIZE));
const firstPageItems = discussions.slice(0, PAGE_SIZE);
---
<MainLayout title={`#${channel?.name ?? slug}`} channels={channels}>
  <Breadcrumbs items={[{ label: 'Channels', href: '/channels' }, { label: `#${channel?.name ?? slug}` }]} />
  <h1 class="text-2xl font-semibold"># {channel?.name}</h1>
  <p class="text-sm text-muted mt-2">Showing newest message batches first.</p>
  <div class="grid gap-4 mt-6">
    {firstPageItems.map((item) => <DiscussionCard item={item} />)}
  </div>
  {totalPages > 1 && (
    <div class="mt-8 flex justify-end">
      <a class="channel-row" href={`/channels/${slug}/page/2`}>Older messages →</a>
    </div>
  )}
</MainLayout>
