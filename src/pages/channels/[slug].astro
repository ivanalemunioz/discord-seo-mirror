---
import { render } from 'astro:content';
import MainLayout from '@/layouts/MainLayout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import { getDiscussions, getChannelNav } from '@/lib/content';

export async function getStaticPaths() {
  const channels = await getChannelNav();
  return channels.map((c) => ({ params: { slug: c.slug } }));
}

const { slug } = Astro.params;
const channels = await getChannelNav();
const channel = channels.find((c) => c.slug === slug);

const channelPages = (await getDiscussions())
  .filter((d) => d.data.channelId === channel?.id)
  .sort((a, b) => a.data.pageNumber - b.data.pageNumber);

const latest = channelPages.at(-1);
const { Content } = latest ? await render(latest) : { Content: null };
---
<MainLayout title={`#${channel?.name ?? slug}`} channels={channels}>
  {latest && Content ? (
    <section>
      <header class="sticky top-0 z-10 bg-background/95 backdrop-blur border-b border-line pb-3">
        <Breadcrumbs items={[{ label: 'Channels', href: '/channels' }, { label: `#${channel?.name ?? slug}` }]} />
        <h1 class="text-xl md:text-2xl font-semibold"># {channel?.name}</h1>
      </header>

      <article id="message-root" class="card p-4 md:p-6 mt-4">
        <div class="mb-4 flex items-center justify-between">
          {latest.data.pageNumber > 1
            ? <a class="text-sm text-blue-300 hover:text-blue-200" href={`/channels/${slug}/page/${latest.data.pageNumber - 1}`}>← Older messages</a>
            : <span class="text-muted text-sm">Start of channel history</span>}
          <span class="text-xs text-muted">Page {latest.data.pageNumber} / {latest.data.totalPages}</span>
        </div>

        <div class="prose prose-invert max-w-none discord-message-stream">
          <Content />
        </div>

        <div class="mt-6 flex justify-between items-center">
          <span class="text-muted text-sm">You are on newest messages</span>
          <a class="text-sm text-blue-300 hover:text-blue-200" href={`/community/${latest.slug}`}>Permalink page ↗</a>
        </div>
      </article>

      <script>
        requestAnimationFrame(() => {
          window.scrollTo({ top: document.documentElement.scrollHeight, behavior: 'auto' });
        });
      </script>
    </section>
  ) : (
    <p class="text-muted mt-4">No messages synced yet for this channel.</p>
  )}
</MainLayout>
