---
import MainLayout from '@/layouts/MainLayout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import MessageItem from '@/components/MessageItem.astro';
import { getChannelNav, getThreadById } from '@/lib/content';
import { t } from '@/lib/i18n';

export async function getStaticPaths() {
  const files = Object.keys(import.meta.glob('/src/data/threads/*.json'));
  return files.map((f) => ({ params: { id: f.split('/').pop()?.replace(/\.json$/, '') || '' } }));
}

const { id } = Astro.params;
const channels = await getChannelNav();
const thread = id ? await getThreadById(id) : null;
const parent = channels.find((c) => c.id === thread?.parentChannelId);
const inviteUrl = process.env.DISCORD_INVITE_URL || '#';

function shouldShowAuthor(messages: Array<{ author: string; timestamp: string }>, i: number) {
  const prev = messages[i - 1];
  if (!prev) return true;
  const withinHour = (new Date(messages[i].timestamp).getTime() - new Date(prev.timestamp).getTime()) <= 3600000;
  const sameAuthor = prev.author === messages[i].author;
  return !(sameAuthor && withinHour);
}
---
<MainLayout title={thread ? `Thread · ${thread.name}` : 'Thread'} channels={channels}>
  {thread ? (
    <section>
      <header class="fixed top-0 left-0 right-0 lg:left-[280px] z-20 bg-background/95 backdrop-blur border-b border-line pb-3 px-4 lg:px-8 pt-4">
        <Breadcrumbs items={[
          { label: 'Channels', href: '/channels' },
          { label: `#${parent?.name ?? 'channel'}`, href: parent ? `/channels/${parent.slug}` : '/channels' },
          { label: thread.name }
        ]} />
        <h1 class="text-xl md:text-2xl font-semibold">{thread.name}</h1>
      </header>

      <article id="message-root" class="mt-24 pb-24">
        {thread.messages.map((m, i) => <MessageItem message={m} showAuthor={shouldShowAuthor(thread.messages, i)} />)}
      </article>

      <div class="fixed bottom-4 left-4 right-4 lg:left-[304px] lg:right-8 z-30 group">
        <div class="bg-surface border border-line rounded-lg px-4 py-3 text-sm text-muted text-center hover:border-blurple transition-colors">
          Write a message...
        </div>
        <a href={inviteUrl} target="_blank" rel="noreferrer" class="absolute -top-10 left-1/2 -translate-x-1/2 whitespace-nowrap bg-panel border border-line rounded-md px-3 py-1 text-xs text-slate-200 opacity-0 pointer-events-none group-hover:opacity-100 transition-opacity">
          Join to the community
        </a>
      </div>
    </section>
  ) : (
    <p class="text-muted mt-4">{t('threadNotFound')}</p>
  )}
</MainLayout>
