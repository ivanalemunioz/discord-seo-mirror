---
import MainLayout from '@/layouts/MainLayout.astro';
import { getChannelNav } from '@/lib/content';
import { t } from '@/lib/i18n';
import ChannelIcon from '@/components/ChannelIcon';

const channels = await getChannelNav();
const grouped = new Map<string, typeof channels>();
for (const c of channels) {
  const key = c.category || 'Ungrouped';
  if (!grouped.has(key)) grouped.set(key, [] as any);
  grouped.get(key)!.push(c);
}
---

<MainLayout title={t('channels')} description="Channel list" channels={channels}>
  <h1 class="text-2xl font-semibold">{t('channels')}</h1>

  {[...grouped.entries()].map(([cat, list]) => (
    <section class="mt-6">
      {cat !== 'Ungrouped' ? <h2 class="text-sm uppercase tracking-wide text-muted mb-2">{cat}</h2> : null}
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-3">
        {list.map((c) => (
          <a href={`/channels/${c.slug}`} class="card p-4 hover:border-blurple transition-colors">
            <div class="text-base font-medium flex items-center gap-2">
              <ChannelIcon kind={c.iconKind} className="h-4 w-4 text-muted" />
              <span>{c.name}</span>
            </div>
            <div class="text-sm text-muted mt-1">{c.count} messages</div>
          </a>
        ))}
      </div>
    </section>
  ))}
</MainLayout>
